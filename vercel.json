{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/api"
    },
    {
      "source": "/archimate/:path*",
      "destination": "/api"
    },
    {
      "source": "/diagram/:path*",
      "destination": "/api"
    },
    {
      "source": "/initial-document/:path*",
      "destination": "/api"
    },
    {
      "source": "/secuencia/:path*",
      "destination": "/api"
    }
  ]
}
